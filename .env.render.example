# Render web service
APP_ALLOWED_ORIGINS=https://your-frontend-domain.com
DB_POOL_MAX_SIZE=3
GITHUB_MOCK_ENABLED=false
JASYPT_ENCRYPTOR_PASSWORD=change-me
JASYPT_ENCRYPTOR_ALGORITHM=PBEWITHHMACSHA512ANDAES_256
JASYPT_ENCRYPTOR_KEY_OBTENTION_ITERATIONS=1000
JASYPT_ENCRYPTOR_SALT_GENERATOR_CLASSNAME=org.jasypt.salt.RandomSaltGenerator
JASYPT_ENCRYPTOR_IV_GENERATOR_CLASSNAME=org.jasypt.iv.RandomIvGenerator
JASYPT_ENCRYPTOR_STRING_OUTPUT_TYPE=base64

# Optional:
# If you later switch away from ENC(...) datasource settings, you can reintroduce
# Spring datasource/Flyway env vars here.
# JASYPT_ENCRYPTOR_ALGORITHM=PBEWITHHMACSHA512ANDAES_256
# JASYPT_ENCRYPTOR_IV_GENERATOR_CLASSNAME=org.jasypt.iv.RandomIvGenerator

# Optional external integrations
# GITHUB_TOKEN=
# AI_SERVER_BASE_URL=https://your-ai-service.onrender.com
# AI_SERVER_API_KEY=
